{
  "manifest_version": 3,
  "name": "Nexus Sidebar",
  "version": "1.0.0",
  "description": "Auto-hide left glass sidebar with app tiles and persistent mini app frames.",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_title": "Nexus Sidebar"
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "css": ["sidebar.css"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["sidebar.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
